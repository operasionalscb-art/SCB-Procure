{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role details",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier matching Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User display name"
        },
        "role": {
          "type": "string",
          "enum": ["Admin", "Pejabat Pembuat Komitmen", "Penyedia", "Tamu"],
          "description": "User role access control level"
        }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "SPK": {
      "title": "SPK",
      "description": "Surat Perintah Kerja (SPK) document details",
      "type": "object",
      "properties": {
        "nomorSpk": {
          "type": "string",
          "description": "Official SPK number"
        },
        "namaPaket": {
          "type": "string",
          "description": "Procurement package name"
        },
        "nilaiPengadaan": {
          "type": "number",
          "description": "Procurement value in IDR"
        },
        "namaVendor": {
          "type": "string",
          "description": "Vendor name"
        },
        "tanggalMulai": {
          "type": "string",
          "format": "date",
          "description": "Work start date"
        },
        "tanggalSelesai": {
          "type": "string",
          "format": "date",
          "description": "Work completion date"
        },
        "detailSpesifikasi": {
          "type": "string",
          "description": "Detailed specifications of work"
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "In Progress", "Completed", "Cancelled"],
          "description": "Current progress status of SPK"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "createdBy": {
          "type": "string",
          "description": "Name or role of creator"
        },
        "milestones": {
          "type": "array",
          "description": "Progress milestones list"
        }
      },
      "required": ["nomorSpk", "namaPaket", "nilaiPengadaan", "namaVendor", "tanggalMulai", "tanggalSelesai", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection indexed by authentication UID"
    },
    "spk/{spkId}": {
      "schema": "SPK",
      "description": "SPK document entries tracking procurement details"
    }
  }
}
