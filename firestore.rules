rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. SPK Collection Rules - Read/Write allowed to enable full synchronization with client-side RBAC
    match /spk/{spkId} {
      allow read, write: if true;
    }

    // 2. app_users Collection Rules - Read/Write allowed to support credentials database checking and registration
    match /app_users/{userId} {
      allow read, write: if true;
    }

    // 3. users Collection Rules - Read/Write allowed for storageService profile operations
    match /users/{userId} {
      allow read, write: if true;
    }

    // 4. Global Safety Net
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
